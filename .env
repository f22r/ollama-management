# Ollama Dashboard Environment Variables

# Ollama API endpoint
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Database path (SQLite)
DATABASE_PATH=./data/ollama-dashboard.db

# Log retention in days
LOG_RETENTION_DAYS=30

# Server port
PORT=3000

# Embedding Model for RAG (default: nomic-embed-text)
EMBEDDING_MODEL=nomic-embed-text
